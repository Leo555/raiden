classDiagram
    class Enemy {
        +x: number
        +y: number
        +width: number
        +height: number
        +hp: number
        +speed: number
        +type: ENEMY_TYPES
        +active: boolean
        +movePattern: string
        +flashTimer: number
        +reset(): void
    }
    
    class SpeedyEnemy {
        +dashSpeed: number
        +dashCooldown: number
        +isDashing: boolean
        +dashTimer: number
        +update(dt, playerX, playerY): void
        +dash(): void
    }
    
    class RotatingEnemy {
        +rotationAngle: number
        +rotationSpeed: number
        +fireCooldown: number
        +update(dt, playerX, playerY): void
        +fireRotatingBullets(): void
    }
    
    class SuicideEnemy {
        +explosionRadius: number
        +armingDistance: number
        +isArmed: boolean
        +update(dt, playerX, playerY): void
        +explode(): void
        +checkDetonation(playerX, playerY): boolean
    }
    
    Enemy <|-- SpeedyEnemy
    Enemy <|-- RotatingEnemy
    Enemy <|-- SuicideEnemy

