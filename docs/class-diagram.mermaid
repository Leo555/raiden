classDiagram
    class WeaponSystem {
        +owner: Player
        +bullets: BulletSystem
        +particles: ParticleSystem
        +currentWeapon: WEAPON_TYPES
        +weapons: Map
        +update(dt): void
        +fire(weaponType, x, y, target?): void
        +switchWeapon(type): void
        +upgradeWeapon(type): void
    }
    
    class Weapon {
        <<abstract>>
        +type: WEAPON_TYPES
        +damage: number
        +fireRate: number
        +fireCooldown: number
        +level: number
        +maxLevel: number
        +fire(x, y, target?): void
        +upgrade(): boolean
        +getDescription(): string
    }
    
    class LaserWeapon {
        +laserLength: number
        +laserWidth: number
        +damagePerSecond: number
        +isFiring: boolean
        +laserHitList: Set
        +fire(x, y): void
        +updateLaser(dt): void
        +drawLaser(ctx): void
    }
    
    class HomingWeapon {
        +maxHomingBullets: number
        +turnSpeed: number
        +bulletSpeed: number
        +fire(x, y, target): void
    }
    
    class ExplosiveWeapon {
        +explosionRadius: number
        +explosionDamage: number
        +blastForce: number
        +fire(x, y): void
        +createExplosion(x, y): void
    }
    
    WeaponSystem --> Weapon
    Weapon <|-- LaserWeapon
    Weapon <|-- HomingWeapon
    Weapon <|-- ExplosiveWeapon

