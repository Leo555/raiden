classDiagram
    class ChallengeMode {
        +mode: string
        +timeLimit: number
        +timer: number
        +score: number
        +isActive: boolean
        +leaderboard: Array
        +start(mode): void
        +update(dt): void
        +getTimeRemaining(): number
        +getScore(): number
        +isTimeUp(): boolean
        +saveScore(): void
        +loadLeaderboard(): Array
    }
    
    class TimeAttackMode {
        +targetScore: number
        +enemiesKilled: number
        +update(dt): void
        +checkWinCondition(): boolean
    }
    
    class SurvivalMode {
        +wavesSurvived: number
        +nextWaveTimer: number
        +update(dt): void
        +spawnWave(): void
    }
    
    ChallengeMode <|-- TimeAttackMode
    ChallengeMode <|-- SurvivalMode
