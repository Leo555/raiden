classDiagram
    class AchievementSystem {
        +achievements: Map~string, AchievementStatus~
        +definitions: Object
        +stats: PlayerStats
        +notificationQueue: Array
        +isPaused: boolean
        +init(): void
        +unlock(id): void
        +updateProgress(id, value): void
        +checkCondition(achievement, gameState): boolean
        +showNotification(id): void
        +save(): void
        +load(): void
        +getProgress(id): ProgressInfo
        +getAllAchievements(): Array
        +getUnlockedCount(): number
        +resetAll(): void
    }
    
    class AchievementStatus {
        +id: string
        +unlocked: boolean
        +unlockTime: number
        +progress: number
        +progressMax: number
        +notified: boolean
    }
    
    class PlayerStats {
        +totalKills: number
        +totalBossKills: number
        +maxCombo: number
        +maxScore: number
        +totalPlayTime: number
        +currentGameKills: number
        +currentGameScore: number
        +currentGameStartTime: number
        +noDamageTimer: number
        +resetCurrentGame(): void
        +toJSON(): Object
        +fromJSON(data): void
    }
    
    class AchievementNotification {
        +id: string
        +title: string
        +icon: string
        +timer: number
        +maxTimer: number
        +y: number
        +targetY: number
        +active: boolean
        +update(dt): void
        +draw(ctx): void
    }
    
    AchievementSystem --> AchievementStatus
    AchievementSystem --> PlayerStats
    AchievementSystem --> AchievementNotification

